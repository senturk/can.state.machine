{
  "name": "can-state-machine",
  "version": "1.0.8",
  "type": "module",
  "description": "Can's State Machine to implement state machine programming workflow",
  "main":    "./lib/index.cjs",
  "module":  "./lib/index.mjs",
  "browser": "./dist/can-state-machine.esm.js",
  "exports": {
    ".": {
      "browser": {
        "import":  "./dist/can-state-machine.esm.js",
        "default": "./dist/can-state-machine.min.js"
      },
      "node": {
        "import":  "./lib/index.mjs",
        "require": "./lib/index.cjs"
      },
      "default": "./lib/index.cjs"
    }
  },
  "files": [
    "lib/",
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "webpack --config webpack.config.cjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "finite-state-machine",
    "cn.sntrk",
    "fsm",
    "deepjson"
  ],
  "author": "cn.sntrk",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/senturk/can.state.machine.git"
  },
  "bugs": {
    "url": "https://github.com/senturk/can.state.machine/issues"
  },
  "homepage": "https://github.com/senturk/can.state.machine#readme",
  "devDependencies": {
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "mocha": "^10.2.0"
  }
}